generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TimeEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AppRole {
  ADMIN
  PM
  CONSULTANT
  FINANCE
  VIEWER
}

enum ProjectType {
  FIXED_PRICE        // Llave en mano: precio fijo contractual
  TIME_AND_MATERIAL  // Bolsa de horas: factura por horas consumidas
  STAFFING           // Staffing: tarifa mensual por recurso asignado
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum FxRateType {
  SPOT     // Tasa puntual del día
  AVERAGE  // Promedio del período (mensual/trimestral)
  BUDGET   // Tasa presupuestada al inicio del año fiscal
}

enum AssignmentStatus {
  PLANNED    // Confirmada para el futuro
  ACTIVE     // En ejecución
  PARTIAL    // Asignación parcial activa
  COMPLETED  // Terminada normalmente
  CANCELLED  // Cancelada antes de iniciar
}

enum AllocationMode {
  PERCENTAGE // % de capacidad total
  HOURS      // Horas fijas por semana/mes
}

enum BlockType {
  VACATION
  SICK_LEAVE
  NATIONAL_HOLIDAY
  INTERNAL_BENCH
  TRAINING
  OTHER
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum HealthStatus {
  GREEN
  YELLOW
  RED
}

enum ProjectPhase {
  INITIATION
  PLANNING
  EXECUTION
  MONITORING
  CLOSING
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
  CANCELLED
}

enum RiskStatus {
  OPEN
  MITIGATED
  ACCEPTED
  CLOSED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ChangeRequestType {
  SCOPE
  BUDGET
  SCHEDULE
  RESOURCE
  OTHER
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum AlertType {
  BUDGET_WARNING
  BUDGET_EXCEEDED
  MARGIN_BELOW_THRESHOLD
  ASSIGNMENT_ENDING
  CONSULTANT_OVERLOADED
  FORECAST_DEVIATION
  FX_RATE_MISSING
}

// ─── Modelos de negocio ────────────────────────────────────────────────────────

model Project {
  id              String        @id @default(cuid())
  name            String
  company         String
  country         String
  currency        String
  budget          Decimal       @db.Decimal(14, 2)
  startDate       DateTime
  endDate         DateTime
  description     String?
  projectType     ProjectType   @default(TIME_AND_MATERIAL)
  status          ProjectStatus @default(ACTIVE)
  sellPrice       Decimal?      @db.Decimal(14, 2)
  sellCurrency    String        @default("USD")
  marginThreshold      Decimal?      @db.Decimal(5, 2)
  budgetAlertPct       Decimal       @default(90)    @db.Decimal(5, 2)
  // Gestión de proyecto
  healthStatus         HealthStatus  @default(GREEN)
  completionPct        Decimal?      @db.Decimal(5, 2)
  phase                ProjectPhase  @default(EXECUTION)
  projectManagerEmail  String?
  // Baseline
  baselineBudget       Decimal?      @db.Decimal(14, 2)
  baselineStartDate    DateTime?
  baselineEndDate      DateTime?
  baselineSetAt        DateTime?
  baselineSetBy        String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  timeEntries    TimeEntry[]
  expenses       Expense[]
  forecasts      Forecast[]
  revenueEntries RevenueEntry[]
  assignments    Assignment[]
  snapshots      MonthlySnapshot[]
  alerts         Alert[]
  milestones     Milestone[]
  risks          Risk[]
  issues         Issue[]
  changeRequests ChangeRequest[]
}

model Consultant {
  id             String   @id @default(cuid())
  fullName       String
  email          String?
  role           String
  hourlyRate     Decimal? @db.Decimal(14, 2)
  rateCurrency   String   @default("USD")
  country        String?
  costPerMonth   Decimal? @db.Decimal(14, 2)
  skills         String[] @default([])
  seniority      String?  // "Junior" | "Mid" | "Senior" | "Lead"
  maxHoursPerDay Decimal? @db.Decimal(4, 2)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  timeEntries    TimeEntry[]
  forecasts      Forecast[]
  assignments    Assignment[]
  blocks         ConsultantBlock[]
  capacityConfig CapacityConfig?
  alerts         Alert[]
}

model TimeEntry {
  id            String          @id @default(cuid())
  projectId     String
  consultantId  String
  workDate      DateTime
  hours         Decimal         @db.Decimal(8, 2)
  note          String?
  status        TimeEntryStatus @default(PENDING)
  approvedBy    String?
  approvedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultant Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([consultantId])
  @@index([status])
  @@index([workDate])
}

model Expense {
  id          String   @id @default(cuid())
  projectId   String
  expenseDate DateTime
  category    String
  amount      Decimal  @db.Decimal(14, 2)
  currency    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([expenseDate])
}

model Forecast {
  id             String   @id @default(cuid())
  projectId      String
  consultantId   String
  startDate      String   // ISO "YYYY-MM-DD" — fecha exacta de inicio
  endDate        String   // ISO "YYYY-MM-DD" — fecha exacta de fin
  hoursProjected Decimal  @db.Decimal(10, 2)
  hourlyRate     Decimal? @db.Decimal(14, 2)  // Costo consultor (lo que pagamos)
  sellRate       Decimal? @db.Decimal(14, 2)  // Tarifa de venta al cliente
  currency       String   @default("USD")
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultant Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([consultantId])
}

// Ingresos reconocidos por proyecto (hitos, facturación, etc.)
model RevenueEntry {
  id          String   @id @default(cuid())
  projectId   String
  entryDate   DateTime
  amount      Decimal  @db.Decimal(14, 2)
  currency    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([entryDate])
}

// ─── FX ────────────────────────────────────────────────────────────────────────

model FxConfig {
  id        String   @id @default(cuid())
  baseCode  String
  quoteCode String
  rate      Decimal  @db.Decimal(18, 6)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Historial de tasas con fecha efectiva — evita recalcular el pasado con tasa actual
model FxRateHistory {
  id            String     @id @default(cuid())
  baseCode      String
  quoteCode     String
  rate          Decimal    @db.Decimal(18, 6)
  effectiveDate DateTime
  rateType      FxRateType @default(SPOT)
  source        String?    // "manual", "ecb", "banrep", etc.
  createdBy     String?    // email del usuario que registró la tasa
  createdAt     DateTime   @default(now())

  @@index([baseCode, quoteCode, effectiveDate])
  @@index([rateType])
}

// ─── Usuarios y roles ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  microsoftOid String?  @unique
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles UserRole[]
}

model Role {
  id        String   @id @default(cuid())
  name      AppRole  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserRole[]
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

// ─── Asignaciones y Capacidad ─────────────────────────────────────────────────

model Assignment {
  id             String           @id @default(cuid())
  projectId      String
  consultantId   String
  startDate      DateTime
  endDate        DateTime
  allocationMode AllocationMode   @default(PERCENTAGE)
  allocationPct  Decimal?         @db.Decimal(5, 2)   // 0..100 si mode=PERCENTAGE
  hoursPerPeriod Decimal?         @db.Decimal(8, 2)   // horas/semana o /mes si mode=HOURS
  periodUnit     String?          // "week" | "month"
  status         AssignmentStatus @default(PLANNED)
  role           String?
  note           String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultant Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)

  @@index([consultantId])
  @@index([projectId])
  @@index([startDate, endDate])
  @@index([status])
}

model ConsultantBlock {
  id           String    @id @default(cuid())
  consultantId String
  startDate    DateTime
  endDate      DateTime
  blockType    BlockType @default(OTHER)
  note         String?
  createdAt    DateTime  @default(now())

  consultant Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@index([consultantId, startDate, endDate])
}

model CapacityConfig {
  id              String   @id @default(cuid())
  consultantId    String?  @unique
  country         String?
  hoursPerDay     Decimal  @default(8) @db.Decimal(4, 2)
  workDaysPerWeek Int      @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  consultant Consultant? @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@index([country])
}

// ─── Cierre Mensual ───────────────────────────────────────────────────────────

model MonthlySnapshot {
  id                String   @id @default(cuid())
  projectId         String
  year              Int
  month             Int
  baseCurrency      String
  laborCostActual   Decimal  @db.Decimal(18, 4)
  expensesActual    Decimal  @db.Decimal(18, 4)
  totalCostActual   Decimal  @db.Decimal(18, 4)
  revenueRecognized Decimal  @db.Decimal(18, 4)
  contractValue     Decimal  @db.Decimal(18, 4)
  grossMargin       Decimal  @db.Decimal(18, 4)
  grossMarginPct    Decimal  @db.Decimal(8, 4)
  hoursApproved     Decimal  @db.Decimal(10, 2)
  fxSnapshotJson    Json
  closedBy          String
  closedAt          DateTime @default(now())
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, year, month])
  @@index([year, month])
}

// ─── Alertas ──────────────────────────────────────────────────────────────────

model Alert {
  id           String        @id @default(cuid())
  type         AlertType
  severity     AlertSeverity @default(WARNING)
  projectId    String?
  consultantId String?
  message      String
  metadata     Json?
  resolvedAt   DateTime?
  resolvedBy   String?
  createdAt    DateTime      @default(now())

  project    Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultant Consultant? @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@index([type, resolvedAt])
  @@index([projectId])
  @@index([consultantId])
}

// ─── Auditoría ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  entity    String
  entityId  String
  action    String
  changedBy String
  before    Json?
  after     Json?
  diff      Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([changedBy])
  @@index([createdAt])
}

// ─── Gestión de Proyectos (PMP) ───────────────────────────────────────────────

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  name        String
  description String?
  plannedDate DateTime
  actualDate  DateTime?
  weight      Decimal         @default(0) @db.Decimal(5, 2)
  status      MilestoneStatus @default(PENDING)
  deliverable String?
  acceptedBy  String?
  note        String?
  createdBy   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([plannedDate])
  @@index([status])
}

model Risk {
  id              String     @id @default(cuid())
  projectId       String
  title           String
  description     String?
  probability     Int
  impact          Int
  riskScore       Int
  category        String?
  owner           String?
  mitigationPlan  String?
  contingencyPlan String?
  status          RiskStatus @default(OPEN)
  identifiedAt    DateTime   @default(now())
  resolvedAt      DateTime?
  createdBy       String
  updatedAt       DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([riskScore])
}

model Issue {
  id          String        @id @default(cuid())
  projectId   String
  title       String
  description String?
  severity    IssueSeverity @default(MEDIUM)
  owner       String?
  status      IssueStatus   @default(OPEN)
  resolvedAt  DateTime?
  resolution  String?
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

model ChangeRequest {
  id            String              @id @default(cuid())
  projectId     String
  title         String
  description   String
  type          ChangeRequestType
  impactScope   String?
  impactBudget  Decimal?            @db.Decimal(14, 2)
  impactDays    Int?
  requestedBy   String
  reviewedBy    String?
  status        ChangeRequestStatus @default(PENDING)
  resolvedAt    DateTime?
  resolution    String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}
